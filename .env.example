# ─── Neon PostgreSQL ───────────────────────────────────────────
# Get both URLs from: https://console.neon.tech → your project → Connection Details
# Select "Prisma" from the dropdown to get the correct format

# Pooled connection (used by app at runtime via Neon serverless adapter)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"

# Direct connection (used by Prisma migrations only)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────
NEXTAUTH_SECRET="d6d30a04c9ebb3f007f1e67297db0a741e2bef757f007cfccd69162a9eb095f5"

# On Vercel this must be your production domain, e.g.:
# NEXTAUTH_URL="https://your-app.vercel.app"
# Locally:
NEXTAUTH_URL="http://localhost:3000"
